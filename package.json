{
  "name": "citeproc-plus",
  "version": "1.0.3",
  "description": "Citeproc-js + citation styles bundled",
  "main": "dist/cjs/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./dist/index.js": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dist/cjs/index.js": {
      "types": "./dist/cjs/index.d.ts",
      "default": "./dist/cjs/index.cjs"
    }
  },
  "scripts": {
    "prebuild": "npm run lint && rm -rf build/ && mkdir build && npm run get_styles_commit && npm run get_styles && npm run get_locales_commit && npm run get_locales && ./convert.py && npm run get_citeproc_license",
    "build": "npm run rollup && npm run build:types",
    "rollup": "rm -rf dist/ && rollup -c",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly && tsc -p tsconfig.cjs.json --emitDeclarationOnly",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "lint": "eslint src rollup.config.ts test",
    "test": "vitest run",
    "test:watch": "vitest",
    "get_locales": "wget -q -O build/locales.zip https://github.com/citation-style-language/locales/archive/master.zip && bsdtar -xvf build/locales.zip -C build && rm build/locales.zip",
    "get_locales_commit": "wget -qO- http://api.github.com/repos/citation-style-language/locales/commits/master | jq -r '.sha' > locales_version.txt",
    "get_styles": "wget -q -O build/styles.zip https://github.com/citation-style-language/styles/archive/master.zip && bsdtar -xvf build/styles.zip -C build && rm build/styles.zip",
    "get_styles_commit": "wget -qO- http://api.github.com/repos/citation-style-language/styles/commits/master | jq -r '.sha' > styles_version.txt",
    "get_citeproc_license": "cp node_modules/citeproc-ts/LICENSE ./software_license.txt"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fiduswriter/citeproc-plus.git"
  },
  "keywords": [
    "citeproc",
    "citeproc-js",
    "csl",
    "citations",
    "styles"
  ],
  "author": "Johannes Wilm",
  "license": "LGPL-3.0",
  "bugs": {
    "url": "https://github.com/fiduswriter/citeproc-plus/issues"
  },
  "homepage": "https://github.com/fiduswriter/citeproc-plus#readme",
  "dependencies": {
    "citeproc-ts": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-commonjs": "^25.0.8",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.1",
    "rollup": "^3.29.5",
    "rollup-plugin-rebase": "^4.1.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "updates": "^15.3.1",
    "vitest": "^4.1.9"
  },
  "files": [
    "LICENSE",
    "locale_licenses.txt",
    "software_licenses.txt",
    "licenses.txt",
    "dist/*",
    "locales_version.txt",
    "styles_version.txt"
  ]
}
